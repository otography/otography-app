{
	"name": "otography-app",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"lint:type-aware": "turbo run lint:type-aware",
		"lint:github": "turbo run lint:github",
		"lint:fix": "turbo run lint:fix",
		"lint:fix:type-aware": "turbo run lint:fix:type-aware",
		"_lint": "oxlint .",
		"_lint:type-aware": "oxlint --type-aware .",
		"_lint:github": "oxlint --format=github .",
		"_lint:fix": "oxlint --fix .",
		"_lint:fix:type-aware": "oxlint --type-aware --fix .",
		"format": "turbo run format",
		"format:fix": "turbo run format:fix",
		"_format": "oxfmt --check .",
		"_format:fix": "oxfmt .",
		"quality": "turbo run quality",
		"quality:fix": "turbo run quality:fix",
		"check-types": "turbo run check-types",
		"check-dead-code": "knip --exclude binaries",
		"check-dead-code:fix": "knip --fix --exclude binaries",
		"hooks:install": "lefthook install"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.38.4",
		"knip": "^6.0.2",
		"lefthook": "^2.1.4",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"turbo": "^2.8.17",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.10"
}
