{
	"name": "otography-app",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "oxlint --type-aware .",
		"lint:github": "oxlint --type-aware --format=github .",
		"lint:fix": "oxlint --type-aware --fix .",
		"format": "oxfmt --check .",
		"format:fix": "oxfmt .",
		"quality": "turbo run quality",
		"quality:fix": "turbo run quality:fix",
		"check-types": "turbo run check-types",
		"hooks:install": "lefthook install"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.38.4",
		"lefthook": "^2.1.4",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"turbo": "^2.8.17",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.10"
}
