{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  // drizzle.config.ts loads env vars at top level, disable plugin
  "drizzle": false,
  // Root workspace — no source files at root level
  "entry": [],
  "project": [],
  // Exclude non-source directories
  "ignore": [".agents/**", ".claude/**", ".factory/**"],
  "tags": ["-db-schema"],
  "workspaces": {
    "packages/typescript-config": {
      "entry": [],
      "project": [],
      // tsconfig plugin references are not code imports
      "ignoreDependencies": ["next"],
    },
    "packages/eslint-config": {
      "entry": [],
      "project": [],
    },
    "apps/web": {
      "entry": ["src/env.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      // @stylexjs/open-props: next.config.ts が transpilePackages/stylexImports に
      // 文字列で渡すのみで import 文がないため knip の静的解析では検出できない
      // @stylexswc/turbopack-plugin: ソースからは直接importされないが、
      // @stylexswc/nextjs-plugin/turbopack が実行時に webpack-loaders.js から
      // apps/web を起点にモジュール解決するため直接依存として必要
      "ignoreDependencies": ["@stylexjs/open-props", "@stylexswc/turbopack-plugin"],
    },
    "apps/api": {
      "entry": [],
      "project": ["src/**/*.ts"],
      "ignore": ["src/env.drizzle.ts"],
      "ignoreDependencies": ["cloudflare"],
    },
  },
}
