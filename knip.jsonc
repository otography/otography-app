{
	"$schema": "https://unpkg.com/knip@6/schema.json",

	// drizzle.config.ts loads env vars at top level, disable plugin
	"drizzle": false,

	// Root workspace — no source files at root level
	"entry": [],
	"project": [],

	// Exclude non-source directories
	"ignore": [".agents/**", ".claude/**"],

	"workspaces": {
		"packages/typescript-config": {
			"entry": [],
			"project": [],
			// tsconfig plugin references are not code imports
			"ignoreDependencies": ["next"],
		},
		"packages/eslint-config": {
			"entry": [],
			"project": [],
		},
		"apps/web": {
			"entry": ["src/env.ts", "lib/**/*.{ts,tsx}", "app/**/*.{ts,tsx}"],
			"project": ["src/**/*.{ts,tsx}", "lib/**/*.{ts,tsx}", "app/**/*.{ts,tsx}"],
		},
		"apps/api": {
			"entry": ["src/index.ts"],
			"project": ["src/**/*.ts"],
		},
	},
}
