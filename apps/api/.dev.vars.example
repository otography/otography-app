# Cloudflare Workers ローカル開発用
# wrangler dev が .dev.vars を読み込む

# Firebase
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Database
DATABASE_URL=

AUTH_OAUTH_STATE_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# サーバーセッション用 AES-256-GCM キーリング。
# hex は `openssl rand -hex 32` で生成し、実値はコミットしない。
AUTH_SESSION_KEY_RING='{"v":1,"activeKeyId":"2026-01","keys":[{"id":"2026-01","hex":"64文字のhex"}]}'
