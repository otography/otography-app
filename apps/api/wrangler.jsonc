{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "src/index.ts",
  "preview_urls": true,
  "compatibility_date": "2025-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "vars": {
    "APP_FRONTEND_URL": "https://web-opal-one-91.vercel.app",
    "FIREBASE_API_KEY": "AIzaSyDqxumBWwkyWSIm3LOkrxBF5JQpqVMElb0",
    "FIREBASE_PROJECT_ID": "otography-676f1",
    "AUTH_COOKIE_DOMAIN": "web-opal-one-91.vercel.app",
    "GOOGLE_OAUTH_REDIRECT_URI": "https://web-opal-one-91.vercel.app/api/auth/google/callback",
  },
  "ratelimits": [
    {
      "name": "LIKE_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 30,
        "period": 60,
      },
    },
    {
      "name": "AUTH_SIGNIN_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 5,
        "period": 60,
      },
    },
    {
      "name": "AUTH_SIGNUP_RATE_LIMITER",
      "namespace_id": "1003",
