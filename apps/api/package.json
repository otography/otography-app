{
	"name": "api",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts"
	},
	"scripts": {
		"dev": "dotenvx run -- bun run --hot src/index.ts",
		"db:generate": "dotenvx run -- bunx drizzle-kit generate",
		"db:migrate": "dotenvx run -- bunx drizzle-kit migrate",
		"db:push": "dotenvx run -- bunx drizzle-kit push",
		"db:studio": "dotenvx run -- bunx drizzle-kit studio",
		"lint": "oxlint",
		"lint:type-aware": "oxlint --type-aware",
		"lint:github": "oxlint --format=github",
		"lint:fix": "oxlint --fix",
		"check-types": "tsc --noEmit",
		"test": "sh -lc 'node ../../node_modules/vitest/vitest.mjs run'"
	},
	"dependencies": {
		"@hono/arktype-validator": "^2.0.1",
		"@repo/errors": "workspace:*",
		"@repo/firebase-auth-rest": "workspace:*",
		"@t3-oss/env-core": "^0.13.10",
		"arktype": "^2.2.0",
		"drizzle-orm": "^1.0.0-beta.19",
		"hono": "^4.12.9",
		"jose": "^6.2.2",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/bun": "latest",
		"@vitest/spy": "^4.1.2",
		"drizzle-kit": "^1.0.0-beta.19",
		"oxlint": "^1.56.0",
		"typescript": "5.9.2"
	}
}
