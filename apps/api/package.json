{
  "name": "api",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf:typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "DATABASE_URL=postgresql://postgres@localhost:54322/postgres DATABASE_DIRECT_URL=postgresql://postgres@localhost:54322/postgres bunx drizzle-kit generate",
    "db:migrate": "DATABASE_URL=postgresql://postgres@localhost:54322/postgres DATABASE_DIRECT_URL=postgresql://postgres@localhost:54322/postgres bunx drizzle-kit migrate",
    "db:push": "DATABASE_URL=postgresql://postgres@localhost:54322/postgres DATABASE_DIRECT_URL=postgresql://postgres@localhost:54322/postgres bunx drizzle-kit push",
    "db:studio": "DATABASE_URL=postgresql://postgres@localhost:54322/postgres DATABASE_DIRECT_URL=postgresql://postgres@localhost:54322/postgres bunx drizzle-kit studio",
    "lint": "oxlint",
    "lint:type-aware": "oxlint --type-aware",
    "lint:github": "oxlint --format=github",
    "lint:fix": "oxlint --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/arktype-validator": "^2.0.1",
    "@repo/errors": "workspace:*",
    "@repo/firebase-auth-rest": "workspace:*",
    "arktype": "^2.2.0",
    "drizzle-orm": "^1.0.0-beta.22",
    "errore": "^0.14.1",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "@vitest/spy": "^4.1.2",
    "drizzle-kit": "^1.0.0-beta.22",
    "oxlint": "^1.56.0",
    "typescript": "5.9.2",
    "wrangler": "^4.80.0"
  }
}
